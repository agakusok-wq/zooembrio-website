---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageBanner from '../components/PageBanner.astro';
import TechnologyAdvantages from '../components/TechnologyAdvantages.astro';
import TechnologyDetail from '../components/TechnologyDetail.astro';
import { getContent } from '../content/site';
import { getLocaleFromUrl } from '../i18n';

const locale = getLocaleFromUrl(Astro.url);
const content = getContent(locale);
---

<BaseLayout>
  <PageBanner title={content.technology.title} subtitle={content.technology.subtitle} palette="technology" />
  <TechnologyAdvantages content={content} />
  <TechnologyDetail content={content} />
</BaseLayout>
