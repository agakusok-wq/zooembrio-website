---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getContent } from '../content/site';
import { getLocaleFromUrl } from '../i18n';

const locale = getLocaleFromUrl(Astro.url);
const content = getContent(locale);
const title = locale === 'ru' ? 'Среды для КРС' : 'Cattle media';
---

<BaseLayout>
  <section class="section-container py-32 text-center">
    <span class="rounded-full bg-brand-navy/10 px-4 py-1 text-sm font-semibold text-brand-navy">
      {locale === 'ru' ? 'Скоро' : 'Coming soon'}
    </span>
    <h1 class="section-title mt-6">{title}</h1>
    <p class="mx-auto mt-4 max-w-xl text-brand-navy/70">
      {
        locale === 'ru'
          ? 'Раздел в разработке. Следите за обновлениями на главной странице.'
          : 'This section is under development. Check the homepage for updates.'
      }
    </p>
    <a href={locale === 'ru' ? '/' : '/en'} class="btn-primary mt-8 inline-flex">
      {locale === 'ru' ? 'На главную' : 'Back to home'}
    </a>
  </section>
</BaseLayout>
