---
import { brandSpotColors } from '../data/brand-colors';
import type { SiteContent } from '../content/site';
import type { Locale } from '../i18n';
import { localizedPath } from '../i18n';
import SpotDots from './SpotDots.astro';
import SpotCardBlob from './SpotCardBlob.astro';

interface Props {
  content: SiteContent;
  locale: Locale;
}

const { content, locale } = Astro.props;
const { advantages } = content.technology;
const cardColors = [
  brandSpotColors.teal,
  brandSpotColors.sky,
  brandSpotColors.wash,
  brandSpotColors.amber,
  brandSpotColors.green,
  brandSpotColors.wam,
];
---

<section class="relative overflow-hidden py-20">
  <div class="section-container relative z-10">
    <div class="mx-auto mb-10 max-w-3xl text-center">
      <SpotDots class="mx-auto mb-4 justify-center" />
      <h2 class="section-title">{content.technology.title}</h2>
      <p class="mt-4 text-brand-navy/70">{content.technology.subtitle}</p>
    </div>

    <div class="tech-cycle mx-auto max-w-5xl">
      <img
        src={content.technology.cycleImage}
        alt={content.technology.cycleImageAlt}
        class="tech-cycle__img"
        loading="lazy"
        width="2560"
        height="1440"
      />
    </div>

    <div class="mx-auto mt-12 max-w-3xl space-y-5 text-center">
      <p class="text-base leading-relaxed text-brand-navy/85">{advantages.intro}</p>
      <p class="text-base leading-relaxed text-brand-navy/80">{advantages.forBreeders}</p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        advantages.items.map((item, i) => (
          <article class="spot-card tech-advantages__card">
            <SpotCardBlob color={cardColors[i]} />
            <span class="tech-advantages__num relative z-10">{i + 1}</span>
            <h3 class="relative z-10 mt-2 font-display text-base font-bold text-brand-navy">
              {item.title}
            </h3>
            <p class="relative z-10 mt-2 text-sm leading-relaxed text-brand-navy/75">{item.text}</p>
          </article>
        ))
      }
    </div>

    <div class="mx-auto mt-12 max-w-3xl text-center">
      <p class="tech-advantages__bridge text-base leading-relaxed text-brand-navy/85">
        {advantages.homeBridge}
      </p>
      <a href={localizedPath('/technology', locale)} class="btn-outline mt-8">
        {locale === 'ru' ? 'Подробнее о технологии' : 'Learn more about the technology'}
      </a>
    </div>
  </div>
</section>
