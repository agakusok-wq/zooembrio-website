---
import type { SiteContent } from '../content/site';
import CowSpots from './CowSpots.astro';
import PhotoSlot from './PhotoSlot.astro';
import SpotDots from './SpotDots.astro';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
---

<section class="relative overflow-hidden bg-brand-cream/40 py-20">
  <CowSpots variant="minimal" palette="about" />
  <div class="section-container relative z-10">
    <SpotDots class="mb-4 justify-center" />
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="section-title">{content.partners.title}</h2>
      <p class="mt-4 text-brand-navy/70">{content.partners.subtitle}</p>
    </div>

    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        content.partners.items.map((partner) => (
          <article class="spot-card flex flex-col">
            <PhotoSlot alt={partner.imageAlt} src={partner.image} class="mb-5" />
            <h3 class="font-display text-lg font-bold text-brand-navy">{partner.name}</h3>
            <p class="mt-1 text-xs font-bold uppercase tracking-wide text-spot-coral">{partner.role}</p>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-brand-navy/75">{partner.text}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
