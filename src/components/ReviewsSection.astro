---
import type { SiteContent } from '../content/site';
import SpotDots from './SpotDots.astro';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
---

<section class="py-20">
  <div class="section-container">
    <SpotDots class="mb-4 justify-center" />
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="section-title">{content.reviews.title}</h2>
      <p class="mt-4 text-brand-navy/70">{content.reviews.subtitle}</p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        content.reviews.items.map((review) => (
          <blockquote class="review-card">
            <p class="review-card__quote">«{review.quote}»</p>
            <footer class="review-card__footer">
              <cite class="review-card__author">{review.author}</cite>
              <span class="review-card__role">{review.role}</span>
            </footer>
          </blockquote>
        ))
      }
    </div>
  </div>
</section>
