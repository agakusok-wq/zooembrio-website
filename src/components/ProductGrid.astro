---
import { brandSpotColors } from '../data/brand-colors';
import type { SiteContent } from '../content/site';
import { localizedPath } from '../i18n';
import type { Locale } from '../i18n';
import SpotDots from './SpotDots.astro';
import SpotCardBlob from './SpotCardBlob.astro';

interface Props {
  locale: Locale;
  content: SiteContent;
}

const { locale, content } = Astro.props;
const spotCardClass: Record<string, string> = {
  teal: 'spot-card--teal',
  orange: 'spot-card--orange',
  green: 'spot-card--green',
  magenta: 'spot-card--magenta',
};
const spotColors: Record<string, string> = {
  teal: brandSpotColors.teal,
  orange: brandSpotColors.wash,
  green: brandSpotColors.green,
  magenta: brandSpotColors.wam,
};
const imageMap: Record<string, string> = {
  'tsm-asp': '/images/products/tsm-asp.svg',
  wash: '/images/products/wash.jpg',
  vit: '/images/products/vit.jpg',
  wam: '/images/products/wam.jpg',
};
---

<section class="relative overflow-hidden bg-brand-cream/50 py-20">
  <div class="section-container relative z-10">
    <div class="mx-auto mb-12 max-w-2xl text-center">
      <SpotDots class="mx-auto mb-4 justify-center" />
      <h2 class="section-title">{content.products.title}</h2>
      <p class="mt-4 text-brand-navy/70">{content.products.subtitle}</p>
    </div>

    <div class="grid gap-8 md:grid-cols-2">
      {
        content.products.groups.map((group) => (
          <article class={`spot-card ${spotCardClass[group.color]}`}>
            <SpotCardBlob color={spotColors[group.color]} variant={group.color} />
            <div class="relative z-10 flex flex-col gap-6 sm:flex-row">
              <div class="flex h-44 w-full shrink-0 items-center justify-center rounded-[1.25rem] bg-white/90 p-4 shadow-sm sm:w-44">
                <img
                  src={imageMap[group.id]}
                  alt={group.name}
                  class="max-h-full max-w-full object-contain"
                  loading="lazy"
                />
              </div>
              <div class="flex-1">
                <div class="mb-2 flex flex-wrap items-center gap-2">
                  {group.step && (
                    <span class="spot-badge-amber">
                      {locale === 'ru' ? `Этап ${group.step}` : `Step ${group.step}`}
                    </span>
                  )}
                  <span class="text-xs font-semibold uppercase tracking-wide text-brand-navy/55">
                    {group.packaging}
                  </span>
                </div>
                <h3 class="font-display text-2xl font-extrabold text-brand-navy">{group.name}</h3>
                <p class="mt-2 text-sm leading-relaxed text-brand-navy/75">{group.description}</p>
                <div class="mt-4 flex flex-wrap gap-2">
                  {group.volumes.map((volume) => (
                    <span class="rounded-full border border-brand-navy/10 bg-white px-3 py-1 text-xs font-bold text-brand-navy">
                      {volume}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <div class="relative z-10 mt-10 text-center">
      <a href={localizedPath('/products', locale)} class="btn-outline">
        {locale === 'ru' ? 'Подробнее о продукции' : 'View all products'}
      </a>
    </div>
  </div>
</section>
