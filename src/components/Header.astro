---
import type { Locale } from '../i18n';
import type { SiteContent } from '../content/site';
import { localizedPath, switchLocalePath } from '../i18n';

interface Props {
  locale: Locale;
  content: SiteContent;
}

const { locale, content } = Astro.props;
const otherLocale = locale === 'ru' ? 'en' : 'ru';
const switchHref = switchLocalePath(Astro.url.pathname, otherLocale);
---

<header class="sticky top-0 z-50 border-b border-brand-navy/5 bg-white/85 backdrop-blur-lg">
  <div class="section-container flex h-16 items-center justify-between gap-4">
    <a href={localizedPath('/', locale)} class="flex items-center gap-3">
      <img src="/images/logo/art-logo.png" alt="АРТ" class="h-12 w-auto max-w-[140px] object-contain" width="140" height="48" />
      <span class="hidden font-display text-sm font-bold tracking-wide text-brand-navy sm:block">ZOOEMBRIO</span>
    </a>

    <nav class="hidden items-center gap-6 md:flex">
      {
        content.nav.map((item) => (
          <a
            href={localizedPath(item.href, locale)}
            class="text-sm font-semibold text-brand-navy/75 transition hover:text-spot-coral"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={switchHref}
        class="rounded-full border-2 border-brand-navy/10 px-3 py-1 text-xs font-bold text-brand-navy transition hover:border-spot-sky hover:text-spot-coral"
      >
        {otherLocale.toUpperCase()}
      </a>
      <a href={localizedPath('/contact', locale)} class="btn-primary hidden sm:inline-flex">
        {content.hero.ctaPrimary}
      </a>
    </div>
  </div>

  <nav class="flex gap-4 overflow-x-auto border-t border-brand-navy/5 px-4 py-2 md:hidden">
    {
      content.nav.map((item) => (
        <a
          href={localizedPath(item.href, locale)}
          class="whitespace-nowrap text-xs font-semibold text-brand-navy/75"
        >
          {item.label}
        </a>
      ))
    }
  </nav>
</header>
